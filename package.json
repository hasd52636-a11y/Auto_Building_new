{
  "name": "react-example",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite --port=3000 --host=0.0.0.0",
    "build": "npx tsx scripts/generate-api.ts && vite build",
    "preview": "vite preview",
    "clean": "rm -rf dist",
    "lint": "tsc --noEmit",
    "scrape": "npx tsx scripts/scrape-all.ts",
    "classify": "npx tsx scripts/classify.ts",
    "process": "npx tsx scripts/process-approved.ts",
    "publish": "npx tsx scripts/publish.ts",
    "daily": "npm run scrape && npm run classify && npm run process && npm run publish"
  },
  "dependencies": {
    "@google/genai": "^1.29.0",
    "@octokit/rest": "^22.0.1",
